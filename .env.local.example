# Copy to .env.local and fill in values.
# This project dev's against the **live/hosted Supabase** project (no local CLI stack).

# --- Supabase (hosted project) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Order emails ---
# Sent by the `send-order-email` Supabase Edge Function via Gmail SMTP,
# triggered by a DB webhook on orders INSERT. No env vars needed here.

# --- Google Apps Script webhook (order logging spreadsheet) ---
# Optional for local dev.
GOOGLE_SHEET_WEBHOOK_URL=
